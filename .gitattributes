# Normalise all text files to LF in the repo.
# Git will convert to the platform's native line endings on checkout
# (CRLF on Windows, LF on WSL/Linux/macOS).
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks shebangs on Unix
*.sh text eol=lf

# Windows-only scripts get CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source files — always LF
*.clj  text eol=lf
*.cljs text eol=lf
*.cljc text eol=lf
*.edn  text eol=lf
*.zil  text eol=lf
*.zap  text eol=lf
*.md   text eol=lf

# Binary files — never mangle these
*.zip    binary
*.z3     binary
*.z5     binary
*.z8     binary
*.xzap   binary
*.cmp    binary
*.record binary
