{:rooms
 {:west-of-house
  {:desc    "West of House"
   :exits   {:north :north-of-house
             :ne    :north-of-house
             :south :south-of-house
             :se    :south-of-house
             :west  :forest-1
             :east  "The door is boarded and you can't remove the boards."
             :sw    {:to :stone-barrow :if :won-flag}
             :in    {:to :stone-barrow :if :won-flag}}
   :action  :west-house
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:white-house :board :forest}}

  :north-of-house
  {:desc  "North of House"
   :ldesc "You are facing the north side of a white house. There is no door here, and all the windows are boarded up. To the north a narrow path winds through the trees."
   :exits {:sw    :west-of-house
           :west  :west-of-house
           :se    :east-of-house
           :east  :east-of-house
           :north :path
           :south "The windows are all boarded."}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:boarded-window :board :white-house :forest}}

  :south-of-house
  {:desc  "South of House"
   :ldesc "You are facing the south side of a white house. There is no door here, and all the windows are boarded."
   :exits {:west  :west-of-house
           :nw    :west-of-house
           :east  :east-of-house
           :ne    :east-of-house
           :south :forest-3
           :north "The windows are all boarded."}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:boarded-window :board :white-house :forest}}

  :east-of-house
  {:desc   "Behind House"
   :action :east-house
   :exits  {:north :north-of-house
            :nw    :north-of-house
            :south :south-of-house
            :sw    :south-of-house
            :east  :clearing
            :west  {:to :kitchen :if-open :kitchen-window}
            :in    {:to :kitchen :if-open :kitchen-window}}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:white-house :kitchen-window :forest}}

  :stone-barrow
  {:desc  "Stone Barrow"
   :ldesc "You are standing in front of a massive barrow of stone. In the east face is a huge stone door which is open. You cannot see into the dark of the tomb."
   :action :stone-barrow-fcn
   :exits  {:ne :west-of-house}
   :flags  #{:rlandbit :onbit :sacredbit}}

  :forest-1
  {:desc   "Forest"
   :ldesc  "This is a forest, with trees in all directions. To the east, there appears to be sunlight."
   :action :forest-room
   :exits  {:north :grating-clearing
            :east  :path
            :south :forest-3
            :up    "There is no tree here suitable for climbing."
            :west  "You would need a machete to go further west."}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:tree :songbird :white-house :forest}}

  :forest-2
  {:desc   "Forest"
   :ldesc  "This is a dimly lit forest, with large trees all around."
   :action :forest-room
   :exits  {:up    "There is no tree here suitable for climbing."
            :north "The forest becomes impenetrable to the north."
            :east  :mountains
            :south :clearing
            :west  :path}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:tree :songbird :white-house :forest}}

  :forest-3
  {:desc   "Forest"
   :ldesc  "This is a dimly lit forest, with large trees all around."
   :action :forest-room
   :exits  {:up    "There is no tree here suitable for climbing."
            :north :clearing
            :east  "The rank undergrowth prevents eastward movement."
            :south "Storm-tossed trees block your way."
            :west  :forest-1
            :nw    :south-of-house}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:tree :songbird :white-house :forest}}

  :mountains
  {:desc  "Forest"
   :ldesc "The forest thins out, revealing impassable mountains."
   :exits {:up    "The mountains are impassable."
           :north :forest-2
           :east  "The mountains are impassable."
           :south :forest-2
           :west  :forest-2}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:tree :white-house}}

  :path
  {:desc   "Forest Path"
   :ldesc  "This is a path winding through a dimly lit forest. The path heads north-south here. One particularly large tree with some low branches stands at the edge of the path."
   :action :forest-room
   :exits  {:up    :up-a-tree
            :north :grating-clearing
            :east  :forest-2
            :south :north-of-house
            :west  :forest-1}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:tree :songbird :white-house :forest}}

  :up-a-tree
  {:desc   "Up a Tree"
   :action :tree-room
   :exits  {:down :path
            :up   "You cannot climb any higher."}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:tree :forest :songbird :white-house}}

  :grating-clearing
  {:desc   "Clearing"
   :action :clearing-fcn
   :exits  {:north "The forest becomes impenetrable to the north."
            :east  :forest-2
            :west  :forest-1
            :south :path
            :down  "You can't go that way."}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:white-house :grate}}

  :clearing
  {:desc   "Clearing"
   :ldesc  "You are in a small clearing in a well marked forest path that extends to the east and west."
   :action :forest-room
   :exits  {:up    "There is no tree here suitable for climbing."
            :east  :canyon-view
            :north :forest-2
            :south :forest-3
            :west  :east-of-house}
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:tree :songbird :white-house :forest}}

  ;; ── White house interior ───────────────────────────────────────────────────

  :kitchen
  {:desc   "Kitchen"
   :action :kitchen-fcn
   :exits  {:east {:to :east-of-house :if-open :kitchen-window}
            :out  {:to :east-of-house :if-open :kitchen-window}
            :west :living-room
            :up   :attic
            :down "Only Santa Claus climbs down chimneys."}
   :flags   #{:rlandbit :onbit :sacredbit}
   :value   10
   :globals #{:kitchen-window :chimney :stairs}}

  :attic
  {:desc  "Attic"
   :ldesc "This is the attic. The only exit is a stairway leading down."
   :exits {:down :kitchen}
   :flags #{:rlandbit :sacredbit}
   :globals #{:stairs}}

  :living-room
  {:desc   "Living Room"
   :action :living-room-fcn
   :exits  {:west "The door is nailed shut."
            :east :kitchen
            :down {:to :cellar :if-open :trap-door}}
   ;; TODO: ZIL uses a PER routine (TRAP-DOOR-EXIT, 1actions.zil:567) that gates descent
   ;; on both RUG-MOVED and trap-door :openbit. Current exit only checks :openbit.
   ;; RUG-MOVED gating not yet implemented (pending rug puzzle).
   :flags   #{:rlandbit :onbit :sacredbit}
   :globals #{:stairs}}

  ;; ── Cellar and vicinity ────────────────────────────────────────────────────

  :cellar
  {:desc   "Cellar"
   :action :cellar-fcn
   :exits  {:north :troll-room
            :south :east-of-chasm
            :up    {:to :living-room :if-open :trap-door}
            :west  "You try to ascend the ramp, but it is impossible, and you slide back down."}
   :flags  #{:rlandbit}
   :value  25
   :globals #{:trap-door :stairs}}

  :troll-room
  {:desc  "The Troll Room"
   :ldesc "This is a small room with passages to the east and south and a forbidding hole leading west. Bloodstains and deep scratches (perhaps made by an axe) mar the walls."
   :exits {:south :cellar
           :east  "The troll fends you off with a menacing gesture."
           :west  "The troll fends you off with a menacing gesture."}
   :flags #{:rlandbit}}

  :east-of-chasm
  {:desc  "East of Chasm"
   :ldesc "You are on the east edge of a chasm, the bottom of which cannot be seen. A narrow passage goes north, and the path you are on continues to the east."
   :exits {:north :cellar
           :east  :gallery
           :down  "The chasm probably leads straight to the infernal regions."}
   :flags #{:rlandbit}}

  :gallery
  {:desc  "Gallery"
   :ldesc "This is an art gallery. Most of the paintings have been stolen by vandals with exceptional taste. The vandals left through either the north or west exits."
   :exits {:west :east-of-chasm
           :north :studio}
   :flags #{:rlandbit :onbit}}

  :studio
  {:desc  "Studio"
   :ldesc "This appears to have been an artist's studio. The walls and floors are splattered with paints of 69 different colors. Strangely enough, nothing of value is hanging here. At the south end of the room is an open door (also covered with paint). A dark and narrow chimney leads up from a fireplace; although you might be able to get up it, it seems unlikely you could get back down."
   :exits {:south :gallery
           :up    "You can't get up there with what you're carrying."}
   :flags #{:rlandbit}}}

 :objects
 {:mailbox
  {:location   :west-of-house
   :synonyms   #{:mailbox :box}
   :adjectives #{:small}
   :desc       "small mailbox"
   :flags      #{:contbit :trytakebit}
   :capacity   10
   :action     :mailbox-f}

  :advertisement
  {:location   :mailbox
   :synonyms   #{:advertisement :leaflet :booklet :mail}
   :adjectives #{:small}
   :desc       "leaflet"
   :flags      #{:readbit :takebit :burnbit}
   :ldesc      "A small leaflet is on the ground."
   :text       "\"WELCOME TO ZORK!\n\nZORK is a game of adventure, danger, and low cunning. In it you will explore some of the most amazing territory ever seen by mortals. No computer should be without one!\""
   :size       2}

  :kitchen-window
  {:location   :local-globals
   :synonyms   #{:window}
   :adjectives #{:kitchen :small}
   :desc       "kitchen window"
   :flags      #{:doorbit :ndescbit}
   :action     :kitchen-window-f}

  ;; ZIL source note: trophy-case declared first so L.R. desc looks right.
  ;; In this EDN file objects are a hash-map — declaration order has no effect.
  ;; Comment preserved for ZIL fidelity reference only.
  :trophy-case
  {:location   :living-room
   :synonyms   #{:case}
   :adjectives #{:trophy}
   :desc       "trophy case"
   :flags      #{:transbit :contbit :ndescbit :trytakebit :searchbit}
   :action     :trophy-case-fcn
   :capacity   10000}

  :trap-door
  {:location   :living-room
   :synonyms   #{:door :trapdoor}
   :adjectives #{:trap :dusty}
   :desc       "trap door"
   :flags      #{:doorbit :ndescbit :invisible}
   :action     :trap-door-fcn}

  :map
  {:location   :trophy-case
   :synonyms   #{:parchment :map}
   :adjectives #{:antique :old :ancient}
   :desc       "ancient map"
   :flags      #{:invisible :readbit :takebit}
   :fdesc      "In the trophy case is an ancient parchment which appears to be a map."
   :size       2
   :text       "The map shows a forest with three clearings. The largest clearing contains a house. Three paths leave the large clearing. One of these paths, leading southwest, is marked \"To Stone Barrow.\""}}}

